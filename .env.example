# ==============================================
# 종가배팅앱 환경변수 설정 파일
# 이 파일을 복사하여 .env 로 이름을 바꾸고 실제 값을 입력하세요
# ==============================================

# Google Gemini AI API 키
# https://ai.google.dev/ 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# Flask 설정
FLASK_ENV=development
FLASK_PORT=5001
FLASK_SECRET_KEY=your_secret_key_here

# 투자 자본금 (원)
DEFAULT_CAPITAL=50000000

# 데이터 경로
DATA_DIR=./data

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ==============================================
# 한국투자증권 OpenAPI (KIS) — 모의/실전 주문 연동
# ----------------------------------------------
# 모의: https://apiportal.koreainvestment.com 에서 모의투자 신청 후 발급
# 실전: 동일 포털에서 실전 OpenAPI 신청 + 본인인증 후 발급
# 주의: 종배플러스/오리지널 두 앱이 모의 단계에서는 동일 계좌·키 공유.
#       실전 진입 시 KIS_ENV=prod 로 바꾸고 별도 계좌·키 사용.
# ==============================================
KIS_ENV=mock                  # mock | prod
KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
KIS_ACCOUNT_NO=00000000-01     # 8자리 종합계좌번호 + "-" + 상품코드(2자리)
KIS_CUSTTYPE=P                # P=개인, B=법인 (모의는 P)
